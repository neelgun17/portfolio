---
const groups = [
	{ label: 'Languages', items: ['Python', 'TypeScript', 'JavaScript', 'Go', 'C++', 'C', 'Java', 'SQL'] },
	{ label: 'Frontend', items: ['React', 'Next.js', 'Tailwind CSS', 'HTML / CSS'] },
	{ label: 'Backend', items: ['FastAPI', 'Node.js', 'REST', 'WebSockets'] },
	{ label: 'ML / AI', items: ['PyTorch', 'LangChain', 'MCP', 'LLM agents', 'PINNs'] },
	{ label: 'Data / Streaming', items: ['Apache Flink', 'Kafka', 'MySQL', 'SQLite'] },
	{ label: 'Cloud / Tools', items: ['AWS', 'Docker', 'Linux', 'Git', 'Firebase'] },
];
---

<section
	data-testid="skills"
	id="skills"
	class="border-t border-neutral-200 px-6 py-24 dark:border-neutral-800 md:py-32"
>
	<div class="mx-auto max-w-6xl">
		<p class="mb-3 flex items-center gap-3 font-mono text-xs uppercase tracking-widest text-accent">
			<span class="text-neutral-400 dark:text-neutral-600">02</span>
			/ Stack
		</p>
		<h2 class="mb-12 text-3xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 lg:text-4xl">
			Tools I build with
		</h2>

		<div class="grid gap-x-12 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
			{
				groups.map((g) => (
					<div>
						<h3 class="mb-4 font-mono text-xs uppercase tracking-widest text-neutral-400 dark:text-neutral-500">
							{g.label}
						</h3>
						<ul class="flex flex-wrap gap-2">
							{g.items.map((item) => (
								<li class="rounded-md border border-neutral-200 bg-white px-2.5 py-1 font-mono text-xs text-neutral-700 transition-colors hover:border-accent/40 hover:text-accent dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-300">
									{item}
								</li>
							))}
						</ul>
					</div>
				))
			}
		</div>
	</div>
</section>
