---
import Social from '@components/ui/Social.astro';
---

<footer data-testid="footer" class="border-t border-neutral-200 px-6 py-10 dark:border-neutral-800">
	<div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-6 sm:flex-row">
		<div class="flex flex-col items-center gap-1 sm:items-start">
			<a href="/" class="font-mono text-sm font-bold tracking-tight text-neutral-900 dark:text-neutral-100">
				Neel Gundlapally
			</a>
			<p class="font-mono text-xs text-neutral-400 dark:text-neutral-500">
				© {new Date().getFullYear()} · Built with Astro &amp; Tailwind
			</p>
		</div>
		<div class="flex items-center gap-6">
			<Social />
		</div>
	</div>
</footer>
